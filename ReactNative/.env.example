# Copy this file to .env and fill in your values.
# NOTE: For React Native Firebase, the Firebase config lives in:
#   - android/app/google-services.json  (Android)
#   - ios/GoogleService-Info.plist      (iOS)
# Download both from your Firebase Console > Project Settings > Your Apps.

# The superadmin email (must match the one used in the Electron app)
SUPERADMIN_EMAIL=your-superadmin@gmail.com

# Google Sign-In web client ID (from Firebase Console > Authentication > Sign-in method > Google > Web client ID)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
